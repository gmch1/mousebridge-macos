{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/gmch1/mousebridge-macos/shared/config.schema.json",
  "title": "MouseBridge cross-platform configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "middleAction",
    "backAction",
    "forwardAction",
    "reverseVerticalScroll",
    "reverseHorizontalScroll",
    "scrollLines",
    "dpi"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "middleAction": { "$ref": "#/$defs/action" },
    "backAction": { "$ref": "#/$defs/action" },
    "forwardAction": { "$ref": "#/$defs/action" },
    "reverseVerticalScroll": { "type": "boolean" },
    "reverseHorizontalScroll": { "type": "boolean" },
    "scrollLines": { "type": "integer", "minimum": 0, "maximum": 20 },
    "dpi": { "type": "integer", "minimum": 400, "maximum": 4000 }
  },
  "$defs": {
    "action": {
      "type": "string",
      "maxLength": 128,
      "description": "Empty means pass-through; none consumes; otherwise a canonical shortcut."
    }
  }
}
